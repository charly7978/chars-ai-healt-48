  "version": "1.0.0",
  "type": "module",
  "description": "PPG Cardiac Monitor - Real camera-based photoplethysmography acquisition",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
